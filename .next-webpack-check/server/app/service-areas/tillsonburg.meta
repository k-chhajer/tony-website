{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/service-areas/layout,_N_T_/service-areas/[slug]/layout,_N_T_/service-areas/[slug]/page,_N_T_/service-areas/tillsonburg"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/service-areas/$d$slug/__PAGE__",
    "/service-areas/$d$slug",
    "/service-areas",
    "/_index",
    "/_head"
  ]
}